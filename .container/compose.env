# Public app port on the VPS host.
CXNEXT_APP_PORT=4000
CXNEXT_PORT=4000

# Set this to your public site URL or allowed origin if you want to restrict browser access.
CXNEXT_CORS_ORIGIN=*
CXNEXT_MEDIA_PUBLIC_BASE_URL=http://localhost:4000/media/public

# Database
CXNEXT_DB_ENABLED=true
CXNEXT_DB_HOST=mariadb
CXNEXT_DB_PORT=3306
CXNEXT_DB_USER=root
CXNEXT_DB_PASSWORD=DbPass1@@
CXNEXT_DB_NAME=cxnext_db

# Optional self-update behavior.
CXNEXT_GIT_SYNC_ENABLED=false
CXNEXT_GIT_REPOSITORY_URL=https://github.com/aaran-software/cxnext.git
CXNEXT_GIT_BRANCH=main
CXNEXT_INSTALL_DEPS_ON_START=false
CXNEXT_BUILD_ON_START=false
