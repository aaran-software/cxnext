{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "vite.config.ts",
    "eslint.config.js"
  ],
  "exclude": [
    "apps/web/src/state/**/*",
    "apps/web/src/components/forms/ProtectedRoute.tsx"
  ]
}
