{
  "name": "cxnext",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:web": "vite --config apps/web/vite.config.ts",
    "dev:api": "tsx watch apps/api/src/server.ts",
    "dev:stack": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "build:web": "vite build --config apps/web/vite.config.ts",
    "build:api": "tsup apps/api/src/server.ts --format esm --platform node --out-dir apps/api/dist",
    "build:desktop": "tsup apps/desktop/src/main.ts apps/desktop/src/preload.ts --format esm --platform node --out-dir apps/desktop/dist --external electron",
    "build": "npm run build:api && npm run build:web && npm run build:desktop",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "preview:web": "vite preview --config apps/web/vite.config.ts",
    "start:desktop": "npm run build:desktop && electron apps/desktop/dist/main.js"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^9.39.4",
    "@rolldown/plugin-babel": "^0.2.1",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "electron": "^37.2.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
