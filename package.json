{
  "name": "codexsun",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "cli": "tsx apps/cli/src/index.ts",
    "dev:web": "vite --config apps/ecommerce/web/vite.config.ts",
    "dev:billing-web": "vite --config apps/billing/web/vite.config.ts",
    "dev:api": "tsx watch apps/core/api/src/server.ts",
    "dev:billing-api": "tsx watch apps/billing/api/src/server.ts",
    "dev:stack": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "build:web": "vite build --config apps/ecommerce/web/vite.config.ts",
    "build:billing-web": "vite build --config apps/billing/web/vite.config.ts",
    "build:cli": "tsup apps/cli/src/index.ts --format esm --platform node --out-dir apps/cli/dist",
    "build:api": "tsup apps/core/api/src/server.ts --format esm --platform node --out-dir apps/core/api/dist",
    "build:billing-api": "tsup apps/billing/api/src/server.ts --format esm --platform node --out-dir apps/billing/api/dist",
    "build:desktop": "tsup apps/core/desktop/src/main.ts apps/core/desktop/src/preload.ts --format esm --platform node --out-dir apps/core/desktop/dist --external electron",
    "build:billing-desktop": "tsup apps/billing/desktop/src/main.ts apps/billing/desktop/src/preload.ts --format esm --platform node --out-dir apps/billing/desktop/dist --external electron",
    "build": "npm run build:api && npm run build:web && npm run build:desktop && npm run build:cli",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test:e2e": "playwright test",
    "start:server": "node apps/core/api/dist/server.js",
    "start:desktop": "npm run build:desktop && electron apps/core/desktop/dist/main.js",
    "start:billing-api": "node apps/billing/api/dist/server.js",
    "start:billing-desktop": "npm run build:billing-desktop && electron apps/billing/desktop/dist/main.js"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.91.3",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.577.0",
    "motion": "^12.38.0",
    "mysql2": "^3.20.0",
    "nodemailer": "^8.0.3",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@rolldown/plugin-babel": "^0.2.1",
    "@types/babel__core": "^7.20.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "electron": "^37.2.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
