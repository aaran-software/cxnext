# App
APP_MODE=web
APP_DEBUG=true
APP_SKIP_SETUP_CHECK=true
PORT=4000
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=change-this-secret-to-at-least-16-characters
JWT_EXPIRES_IN_SECONDS=28800
SUPER_ADMIN_EMAILS=admin@example.com


# Frontend
VITE_FRONTEND_TARGET=web
VITE_API_BASE_URL=http://localhost:4000
CXNEXT_WEB_URL=https://tirupurdirect.com


# Database
DB_ENABLED=true
DB_HOST=mariadb
DB_PORT=3306
DB_USER=root
DB_PASSWORD=DbPass1@@
DB_NAME=tirupur_direct_db
WEB_DIST_ROOT=apps/ecommerce/web/dist


# Media Storage
MEDIA_STORAGE_ROOT=storage
MEDIA_PUBLIC_BASE_URL=/media/public
MEDIA_WEB_PUBLIC_SYMLINK=public/storage


# Seed Data
SEED_DEFAULT_USER=true
SEED_DEFAULT_USER_NAME=Sundar
SEED_DEFAULT_USER_EMAIL=sundar@sundar.com
SEED_DEFAULT_USER_PASSWORD=Kalarani1@@
SEED_DEFAULT_USER_AVATAR_URL=https://ui-avatars.com/api/?name=Platform+Admin&background=1f2937&color=ffffff
SEED_DUMMY_PRODUCTS=true


# OTP and Auth
AUTH_OTP_DEBUG=false
AUTH_OTP_EXPIRY_MINUTES=10


# SMTP Mail
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@aaranerp.com
SMTP_PASS=Kalarani1**s
SMTP_FROM_EMAIL=info@aaranerp.com
SMTP_FROM_NAME="Tirupur Direct"


# MSG91
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_TEMPLATE_ID=your_msg91_template_id
MSG91_OTP_BASE_URL=https://api.msg91.com/api/v5/otp
MSG91_WIDGET_VERIFY_URL=https://control.msg91.com/api/v5/widget/verifyAccessToken
MSG91_COUNTRY_CODE=91
VITE_MSG91_WIDGET_ENABLED=false
VITE_MSG91_WIDGET_ID=your_msg91_widget_id
VITE_MSG91_WIDGET_TOKEN_AUTH=your_msg91_widget_token


# WhatsApp
WHATSAPP_ACCESS_TOKEN=your_meta_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_meta_phone_number_id
WHATSAPP_TEMPLATE_NAME=otp_verification
WHATSAPP_TEMPLATE_LANGUAGE=en
WHATSAPP_GRAPH_API_VERSION=v23.0


# Razorpay
RAZORPAY_KEY_ID=rzp_test_change_me
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_BUSINESS_NAME=CXNext
RAZORPAY_CHECKOUT_IMAGE=
RAZORPAY_THEME_COLOR=#1f2937
PAYMENT_TEST_BYPASS=false


# Container Startup
GIT_SYNC_ENABLED=false
GIT_AUTO_UPDATE_ON_START=false
GIT_FORCE_UPDATE_ON_START=false
GIT_REPOSITORY_URL=https://github.com/aaran-software/cxnext.git
GIT_BRANCH=main
INSTALL_DEPS_ON_START=false
BUILD_ON_START=false
